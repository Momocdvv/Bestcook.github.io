        function closeNavModal(e) { if(e.target===document.getElementById('navModalOverlay')) closeNavModalDirect(); }
        document.querySelectorAll('a[href^="#"]').forEach(a => a.addEventListener('click', function(e){ const t=document.querySelector(this.getAttribute('href')); if(t){e.preventDefault(); window.scrollTo({top:t.getBoundingClientRect().top+window.pageYOffset-65,behavior:'smooth'});}}));
